default_platform(:ios)

SCHEME     = "Runner"
WORKSPACE  = "ios/Runner.xcworkspace"
BUNDLE_ID  = "com.splitgenesis.splitGenesis"

platform :ios do

  desc "Build and upload beta to TestFlight"
  lane :beta do
    setup_ci(force: true)

    api_key = app_store_connect_api_key(
      key_id:        ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:     ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:   ENV["APP_STORE_CONNECT_KEY_CONTENT"],
      is_key_content_base64: true
    )

    increment_build_number(
      build_number: latest_testflight_build_number(
        api_key:    api_key,
        app_identifier: BUNDLE_ID
      ) + 1,
      xcodeproj: "ios/Runner.xcodeproj"
    )

    match(
      type:           "appstore",
      app_identifier: [BUNDLE_ID],
      readonly:       true,
      api_key:        api_key
    )

    build_app(
      workspace:      WORKSPACE,
      scheme:         SCHEME,
      configuration:  "Release",
      export_method:  "app-store",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "com.splitgenesis.splitGenesis" => "match AppStore com.splitgenesis.splitGenesis"
        }
      },
      xcargs: "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY=\"Apple Distribution\" DEVELOPMENT_TEAM=\"J7Q9XMR28Y\"",
      output_directory: "fastlane/build",
      output_name:   "SplitGenesis.ipa"
    )

    upload_to_testflight(
      api_key:        api_key,
      app_identifier: BUNDLE_ID,
      ipa:            "fastlane/build/SplitGenesis.ipa",
      skip_waiting_for_build_processing: true
    )

    UI.success "Beta uploaded to TestFlight!"
  end

  error do |lane, exception|
    UI.error "Lane #{lane} failed: #{exception.message}"
  end
end
