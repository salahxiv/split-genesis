  "legalPrivacySection1Title": "1. Data Controller",
  "@legalPrivacySection1Title": {
    "description": "Privacy Policy section 1 title"
  },
  "legalPrivacySection1Body": "Split Genesis is operated by Salah AI Company (\"we\", \"us\", \"our\"). You can reach us at: legal@split-genesis.app\n\nAs the responsible party within the meaning of the DSGVO (GDPR), we are committed to protecting your personal data.",
  "@legalPrivacySection1Body": {
    "description": "Privacy Policy section 1 body (data controller identification)"
  },
  "legalPrivacySection2Title": "2. What Data We Collect",
  "@legalPrivacySection2Title": {
    "description": "Privacy Policy section 2 title"
  },
  "legalPrivacySection2Body": "We collect the minimum data necessary to operate Split Genesis:\n\n• Account data: email address and display name (provided by you at sign-up)\n• Group data: group names, member lists, expense descriptions and amounts\n• Device data: device type and app version (for crash reporting only)\n• Usage data: anonymous feature usage statistics (no personal identifiers)\n\nWe do NOT collect: location, contacts, microphone, camera, or advertising IDs.",
  "@legalPrivacySection2Body": {
    "description": "Privacy Policy section 2 body (data collected, bullet list)"
  },
  "legalPrivacySection3Title": "3. Purpose and Legal Basis (Art. 6 DSGVO)",
  "@legalPrivacySection3Title": {
    "description": "Privacy Policy section 3 title"
  },
  "legalPrivacySection3Body": "Your data is processed for the following purposes:\n\n• To provide the expense-splitting service (Art. 6(1)(b) DSGVO — contract performance)\n• To sync data across your devices via Supabase (Art. 6(1)(b) DSGVO)\n• To detect and fix technical errors (Art. 6(1)(f) DSGVO — legitimate interest)\n\nWe do not process your data for advertising or sell it to third parties.",
  "@legalPrivacySection3Body": {
    "description": "Privacy Policy section 3 body (purpose and legal basis, bullet list with article references)"
  },
  "legalPrivacySection4Title": "4. Data Storage and Processors",
  "@legalPrivacySection4Title": {
    "description": "Privacy Policy section 4 title"
  },
  "legalPrivacySection4Body": "Your data is stored on Supabase infrastructure (PostgreSQL database) hosted in the EU (Frankfurt, Germany). Supabase B.V. acts as our data processor under a Data Processing Agreement (DPA) compliant with Art. 28 DSGVO.\n\nCrash reports are processed by our self-hosted Bugsink instance on Hetzner (Germany). No data is sent to third-party crash analytics providers.",
  "@legalPrivacySection4Body": {
    "description": "Privacy Policy section 4 body (data storage and processors)"
  },
  "legalPrivacySection5Title": "5. Retention Period",
  "@legalPrivacySection5Title": {
    "description": "Privacy Policy section 5 title"
  },
  "legalPrivacySection5Body": "Account and expense data is retained for as long as your account is active. If you delete your account, all associated data (groups, expenses, members) is permanently deleted within 30 days.\n\nAnonymous usage statistics are retained for up to 12 months then auto-deleted.",
  "@legalPrivacySection5Body": {
    "description": "Privacy Policy section 5 body (retention period)"
  },
  "legalPrivacySection6Title": "6. Your Rights (Art. 15–22 DSGVO)",
  "@legalPrivacySection6Title": {
    "description": "Privacy Policy section 6 title"
  },
  "legalPrivacySection6Body": "You have the right to:\n\n• Access: request a copy of all data we hold about you (Art. 15)\n• Rectification: correct inaccurate data (Art. 16)\n• Erasure: delete your account and all data (\"right to be forgotten\", Art. 17)\n• Portability: export your data in machine-readable format (Art. 20)\n• Objection: object to processing based on legitimate interests (Art. 21)\n\nTo exercise your rights, contact us at: legal@split-genesis.app\n\nYou also have the right to lodge a complaint with your local supervisory authority (in Germany: the Datenschutzbeauftragter of your federal state).",
  "@legalPrivacySection6Body": {
    "description": "Privacy Policy section 6 body (data subject rights, bullet list with article references)"
  },
  "legalPrivacySection7Title": "7. How to Delete Your Account",
  "@legalPrivacySection7Title": {
    "description": "Privacy Policy section 7 title"
  },
  "legalPrivacySection7Body": "You can delete your account and all data at any time:\n\n1. Open Settings in Split Genesis\n2. Scroll to the bottom → \"Delete Account\"\n3. Confirm deletion — all data is queued for removal\n4. Complete deletion occurs within 30 days\n\nAlternatively, email us at legal@split-genesis.app with subject \"Account Deletion Request\".",
  "@legalPrivacySection7Body": {
    "description": "Privacy Policy section 7 body (account deletion steps, numbered list)"
  },
  "legalPrivacySection8Title": "8. Children’s Privacy",
  "@legalPrivacySection8Title": {
    "description": "Privacy Policy section 8 title"
  },
  "legalPrivacySection8Body": "Split Genesis is not directed at children under 13 (EU: under 16). We do not knowingly collect data from children. If you believe a child has provided us data, contact us immediately.",
  "@legalPrivacySection8Body": {
    "description": "Privacy Policy section 8 body (children's privacy)"
  },
  "legalPrivacySection9Title": "9. Contact",
  "@legalPrivacySection9Title": {
    "description": "Privacy Policy section 9 title"
  },
  "legalPrivacySection9Body": "Data protection questions: legal@split-genesis.app\nResponse time: within 30 days as required by Art. 12 DSGVO.",
  "@legalPrivacySection9Body": {
    "description": "Privacy Policy section 9 body (contact)"
  },
  "legalLinkPrivacyWeb": "Full Privacy Policy (Web)",
  "@legalLinkPrivacyWeb": {
    "description": "Link-button label opening the full Privacy Policy on the web"
  },
